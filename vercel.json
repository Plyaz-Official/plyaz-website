{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/__redirect-test",
      "destination": "https://example.com",
      "permanent": false
    },
    {
      "source": "/insights",
      "destination": "https://web.plyaz.net/en/blog",
      "permanent": true
    },
    {
      "source": "/insights/(.*)",
      "destination": "https://web.plyaz.net/en/blog/$1",
      "permanent": true
    },
    {
      "source": "/legal",
      "destination": "https://web.plyaz.net/en/legal",
      "permanent": true
    },
    {
      "source": "/legal/(.*)",
      "destination": "https://web.plyaz.net/en/legal/$1",
      "permanent": true
    }
  ]
}
