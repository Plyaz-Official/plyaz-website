# ─── Webapp base URL — destination for /insights + /legal 301s ───────────────
# Set per-env on Vercel so the plyaz-website redirects land on the
# matching webapp surface. Empty / unset → falls back to https://web.plyaz.net
# (the prod webapp) so a misconfigured deploy still routes to something.
#
#   dev     : PUBLIC_WEBAPP_BASE_URL=https://dev-web.plyaz.net
#   staging : PUBLIC_WEBAPP_BASE_URL=https://staging-web.plyaz.net
#   prod    : PUBLIC_WEBAPP_BASE_URL=https://web.plyaz.net
#
# Used by:
#   - src/pages/insights/index.astro       → {BASE}/blog
#   - src/pages/insights/[...slug].astro   → {BASE}/blog/{slug}
#   - src/pages/legal/[...slug].astro      → {BASE}/legal/{slug}
PUBLIC_WEBAPP_BASE_URL=https://web.plyaz.net
