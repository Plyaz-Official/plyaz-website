---
/**
 * /legal/[...slug] → https://web.plyaz.net/en/legal/[...slug]
 *
 * Plain static page with meta-refresh + JS fallback. Same shape as
 * `insights/[...slug]`.
 */
export const prerender = false;
const slug = Astro.params.slug ?? '';
const DEST = `https://web.plyaz.net/en/legal/${slug}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${DEST}`} />
    <link rel="canonical" href={DEST} />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>Redirecting to <a href={DEST}>{DEST}</a>…</p>
    <script set:html={`window.location.replace(${JSON.stringify(DEST)});`} />
  </body>
</html>
