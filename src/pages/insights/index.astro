---
/**
 * /insights → redirect to {PUBLIC_WEBAPP_BASE_URL}/blog
 *
 * The plyaz webapp now owns the editorial surface end-to-end (Strapi
 * CMS + comments + reactions + per-viewport focal points). This file
 * used to render the local Keystatic-backed insights index; it now
 * 301s every visitor to the webapp's `/blog` route so editors maintain
 * a single canonical surface instead of forking content here.
 *
 * Per-env destination via `PUBLIC_WEBAPP_BASE_URL`:
 *   - dev      : https://dev-web.plyaz.net    (when provisioned)
 *   - staging  : https://staging-web.plyaz.net
 *   - prod     : https://web.plyaz.net
 *
 * Falls back to https://web.plyaz.net when the env var is unset so a
 * misconfigured deploy still routes to a working surface. The local
 * Keystatic content folder (`src/content/insights/`) stays in place
 * as source of truth for the prod CMS seed script (phase 3).
 *
 * `output: 'static'` emits a redirect HTML page; the Vercel adapter
 * additionally honours the status code at the platform level for true
 * HTTP 301s on the edge.
 */
const BASE = import.meta.env.PUBLIC_WEBAPP_BASE_URL ?? 'https://web.plyaz.net';
return Astro.redirect(`${BASE}/blog`, 301);
---
