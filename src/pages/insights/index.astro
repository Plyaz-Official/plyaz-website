---
import { getCollection } from 'astro:content';
import MainLayout from "../../layouts/MainLayout.astro";
import Insights from "../../components/PostGrid/index.astro";

const pageTitle = "Insights";

const allPosts = await getCollection('insights');
const publishedPosts = allPosts.sort((a, b) => {
  const dateA = a.data.publishDate ? new Date(a.data.publishDate).getTime() : 0;
  const dateB = b.data.publishDate ? new Date(b.data.publishDate).getTime() : 0;
  return dateB - dateA;
});
---

<MainLayout pageTitle={pageTitle}>
  <Insights items={publishedPosts} />
</MainLayout>