---
export const prerender = false;
import { getCollection } from 'astro:content';
import MainLayout from "../../layouts/MainLayout.astro";
import Insights from "../../components/PostGrid/index.astro";

const pageTitle = "Insights";

const allPosts = await getCollection('insights');
const publishedPosts = allPosts.filter(post => {
  if (!post.data.publishDate) return true;
  return new Date(post.data.publishDate) <= new Date();
});
---

<MainLayout pageTitle={pageTitle}>
  <Insights items={publishedPosts} />
</MainLayout>