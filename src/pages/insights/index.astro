---
/**
 * /insights → https://web.plyaz.net/en/blog
 *
 * Plain static page with a one-line meta-refresh + JS fallback. The
 * adapter-level redirect chain (vercel.json / Astro redirects config
 * / SSR Response) was burned through earlier in this PR series with
 * no working result. This is the cheap path that actually ships:
 * static HTML → instant client navigation.
 */
const DEST = 'https://web.plyaz.net/en/blog';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${DEST}`} />
    <link rel="canonical" href={DEST} />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>Redirecting to <a href={DEST}>{DEST}</a>…</p>
    <script set:html={`window.location.replace(${JSON.stringify(DEST)});`} />
  </body>
</html>
