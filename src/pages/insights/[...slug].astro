---
/**
 * /insights/[slug] → redirect to {PUBLIC_WEBAPP_BASE_URL}/blog/[slug]
 *
 * Single-canonical-surface migration: the plyaz webapp now hosts every
 * article via Strapi CMS, with comments + reactions + per-viewport
 * focal points. This page used to render the local markdoc content;
 * it now 301s straight to the webapp's `/blog/{slug}` so existing
 * inbound links + bookmarks keep working without forking content.
 *
 * `getStaticPaths` still enumerates every local insight slug so each
 * one builds a redirect HTML page (the Vercel adapter materialises
 * each redirect as a true HTTP 301 at the edge). Without the path
 * enumeration, only the parametric route would exist and direct
 * crawler hits to a known slug would 404 before the redirect ran.
 *
 * Falls back to https://web.plyaz.net when `PUBLIC_WEBAPP_BASE_URL`
 * is unset.
 */
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { slug: post.id },
  }));
}

const { slug } = Astro.props as { slug: string };
const BASE = import.meta.env.PUBLIC_WEBAPP_BASE_URL ?? 'https://web.plyaz.net';
return Astro.redirect(`${BASE}/blog/${slug}`, 301);
---
