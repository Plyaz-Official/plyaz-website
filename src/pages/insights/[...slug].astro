---
/**
 * /insights/[...slug] → https://web.plyaz.net/en/blog/[...slug]
 *
 * Plain static page with meta-refresh + JS fallback. `prerender =
 * false` keeps it as an SSR endpoint so any slug works without
 * getStaticPaths enumeration — the function just builds the
 * destination URL on the fly and renders the redirect shim.
 */
export const prerender = false;
const slug = Astro.params.slug ?? '';
const DEST = `https://web.plyaz.net/en/blog/${slug}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${DEST}`} />
    <link rel="canonical" href={DEST} />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>Redirecting to <a href={DEST}>{DEST}</a>…</p>
    <script set:html={`window.location.replace(${JSON.stringify(DEST)});`} />
  </body>
</html>
